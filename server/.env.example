# Copy this file to `.env` and fill in your local values.
# The real `.env` is gitignored.

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lau_library
# Set DB_SSL=true when connecting to a managed cloud DB (Railway, PlanetScale, etc.)
DB_SSL=false

# --- Auth ---
# Any long random string. Generate with: openssl rand -base64 48
JWT_SECRET=change-me

# --- Server ---
PORT=5000
